// OpenCL function definitions for dynamic loading
// Format: OCL_FUNC(name, required)
// where 'required' is 1 for OpenCL 1.0 functions that must be present, 0 for optional

// OpenCL 1.0 - Required
OCL_FUNC(clGetPlatformIDs, 1)
OCL_FUNC(clGetPlatformInfo, 1)
OCL_FUNC(clGetDeviceIDs, 1)
OCL_FUNC(clGetDeviceInfo, 1)
OCL_FUNC(clCreateContext, 1)
OCL_FUNC(clCreateContextFromType, 1)
OCL_FUNC(clRetainContext, 1)
OCL_FUNC(clReleaseContext, 1)
OCL_FUNC(clGetContextInfo, 1)
OCL_FUNC(clCreateCommandQueue, 1)
OCL_FUNC(clRetainCommandQueue, 1)
OCL_FUNC(clReleaseCommandQueue, 1)
OCL_FUNC(clGetCommandQueueInfo, 1)
OCL_FUNC(clCreateBuffer, 1)
OCL_FUNC(clRetainMemObject, 1)
OCL_FUNC(clReleaseMemObject, 1)
OCL_FUNC(clGetMemObjectInfo, 1)
OCL_FUNC(clGetImageInfo, 1)
OCL_FUNC(clCreateSampler, 1)
OCL_FUNC(clRetainSampler, 1)
OCL_FUNC(clReleaseSampler, 1)
OCL_FUNC(clGetSamplerInfo, 1)
OCL_FUNC(clCreateProgramWithSource, 1)
OCL_FUNC(clCreateProgramWithBinary, 1)
OCL_FUNC(clRetainProgram, 1)
OCL_FUNC(clReleaseProgram, 1)
OCL_FUNC(clBuildProgram, 1)
OCL_FUNC(clGetProgramInfo, 1)
OCL_FUNC(clGetProgramBuildInfo, 1)
OCL_FUNC(clCreateKernel, 1)
OCL_FUNC(clCreateKernelsInProgram, 1)
OCL_FUNC(clRetainKernel, 1)
OCL_FUNC(clReleaseKernel, 1)
OCL_FUNC(clSetKernelArg, 1)
OCL_FUNC(clGetKernelInfo, 1)
OCL_FUNC(clGetKernelWorkGroupInfo, 1)
OCL_FUNC(clWaitForEvents, 1)
OCL_FUNC(clGetEventInfo, 1)
OCL_FUNC(clRetainEvent, 1)
OCL_FUNC(clReleaseEvent, 1)
OCL_FUNC(clGetEventProfilingInfo, 1)
OCL_FUNC(clFlush, 1)
OCL_FUNC(clFinish, 1)
OCL_FUNC(clEnqueueReadBuffer, 1)
OCL_FUNC(clEnqueueWriteBuffer, 1)
OCL_FUNC(clEnqueueCopyBuffer, 1)
OCL_FUNC(clEnqueueReadImage, 1)
OCL_FUNC(clEnqueueWriteImage, 1)
OCL_FUNC(clEnqueueCopyImage, 1)
OCL_FUNC(clEnqueueCopyImageToBuffer, 1)
OCL_FUNC(clEnqueueCopyBufferToImage, 1)
OCL_FUNC(clEnqueueMapBuffer, 1)
OCL_FUNC(clEnqueueMapImage, 1)
OCL_FUNC(clEnqueueUnmapMemObject, 1)
OCL_FUNC(clEnqueueNDRangeKernel, 1)
OCL_FUNC(clEnqueueNativeKernel, 0)
OCL_FUNC(clEnqueueMarker, 1)
OCL_FUNC(clEnqueueWaitForEvents, 1)
OCL_FUNC(clEnqueueBarrier, 1)
OCL_FUNC(clGetExtensionFunctionAddress, 1)

// OpenCL 1.1 - Optional
OCL_FUNC(clCreateSubBuffer, 0)
OCL_FUNC(clSetMemObjectDestructorCallback, 0)
OCL_FUNC(clCreateUserEvent, 0)
OCL_FUNC(clSetUserEventStatus, 0)
OCL_FUNC(clSetEventCallback, 0)
OCL_FUNC(clEnqueueReadBufferRect, 0)
OCL_FUNC(clEnqueueWriteBufferRect, 0)
OCL_FUNC(clEnqueueCopyBufferRect, 0)
OCL_FUNC(clCreateSubDevices, 0)
OCL_FUNC(clRetainDevice, 0)
OCL_FUNC(clReleaseDevice, 0)

// OpenCL 1.2 - Optional
OCL_FUNC(clCreateImage, 0)
OCL_FUNC(clCompileProgram, 0)
OCL_FUNC(clLinkProgram, 0)
OCL_FUNC(clUnloadPlatformCompiler, 0)
OCL_FUNC(clGetKernelArgInfo, 0)
OCL_FUNC(clEnqueueFillBuffer, 0)
OCL_FUNC(clEnqueueFillImage, 0)
OCL_FUNC(clEnqueueMigrateMemObjects, 0)
OCL_FUNC(clEnqueueMarkerWithWaitList, 0)
OCL_FUNC(clEnqueueBarrierWithWaitList, 0)
OCL_FUNC(clGetExtensionFunctionAddressForPlatform, 0)

// OpenCL 2.0 - Optional
OCL_FUNC(clCreateCommandQueueWithProperties, 0)
OCL_FUNC(clCreatePipe, 0)
OCL_FUNC(clGetPipeInfo, 0)
OCL_FUNC(clSVMAlloc, 0)
OCL_FUNC(clSVMFree, 0)
OCL_FUNC(clCreateSamplerWithProperties, 0)
OCL_FUNC(clSetKernelArgSVMPointer, 0)
OCL_FUNC(clSetKernelExecInfo, 0)
OCL_FUNC(clEnqueueSVMFree, 0)
OCL_FUNC(clEnqueueSVMMemcpy, 0)
OCL_FUNC(clEnqueueSVMMemFill, 0)
OCL_FUNC(clEnqueueSVMMap, 0)
OCL_FUNC(clEnqueueSVMUnmap, 0)

// OpenCL 2.1 - Optional
OCL_FUNC(clCreateProgramWithIL, 0)
OCL_FUNC(clGetHostTimer, 0)
OCL_FUNC(clGetDeviceAndHostTimer, 0)

// OpenCL 2.2 - Optional
OCL_FUNC(clSetProgramSpecializationConstant, 0)
OCL_FUNC(clSetProgramReleaseCallback, 0)

// OpenCL 3.0 - Optional
OCL_FUNC(clCreateBufferWithProperties, 0)
OCL_FUNC(clCreateImageWithProperties, 0)
OCL_FUNC(clSetContextDestructorCallback, 0)
