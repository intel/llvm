// Test the --time flag on the `static-library create` subcommand.

// RUN: rm -rf %t
// RUN: mkdir -p %t

// RUN: clang-ssaf-linker static-library create --time \
// RUN:     %S/Inputs/tu-1.json %S/Inputs/tu-2.json -o %t/libt.json 2>&1 \
// RUN:   | FileCheck %s --match-full-lines

// CHECK:      ===-------------------------------------------------------------------------===
// CHECK-NEXT: {{[ ]+}}SSAF Linker
// CHECK-NEXT: ===-------------------------------------------------------------------------===
// CHECK-NEXT:   Total Execution Time: {{[0-9.]+}} seconds ({{[0-9.]+}} wall clock)
// CHECK:      {{.*}}---Wall Time---{{.*}}
// CHECK-DAG:  {{.*}}Validate Input
// CHECK-DAG:  {{.*}}Read Summaries
// CHECK-DAG:  {{.*}}Assemble StaticLibrary
// CHECK-DAG:  {{.*}}Write StaticLibrary
// CHECK:      {{.*}}Total
