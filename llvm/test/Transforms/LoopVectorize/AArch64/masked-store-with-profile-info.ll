entry:
  br label %loop

loop:
  %iv = phi i64 [ 0, %entry ], [ %iv.next, %latch ]
  %gep.b = getelementptr inbounds i32, ptr %b, i64 %iv
  %val = load i32, ptr %gep.b, align 4
  %cmp = icmp sgt i32 %val, 0
  br i1 %cmp, label %if.then, label %latch, !prof !1

if.then:
