entry:
  br label %loop

loop:
  %iv = phi i32 [ 0, %entry ], [ %iv.next, %latch ]
  %gep = getelementptr inbounds i32, ptr %a, i32 %iv
  %val = load i32, ptr %gep, align 4
  %cmp = icmp sgt i32 %val, 0
  br i1 %cmp, label %if.then, label %latch, !prof !1

if.then:
  store i32 0, ptr %gep, align 4
