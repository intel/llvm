  %e3 = extractelement <4 x i1> %m, i32 2
  %x3 = extractelement <4 x float> %x, i32 2
  %y3 = extractelement <4 x float> %y, i32 2
  %s3 = select nnan i1 %e3, float %x3, float %y3
