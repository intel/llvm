; NOTE: Assertions have been autogenerated by utils/update_test_checks.py
; RUN: opt -passes=gvn -S %s | FileCheck %s

; Test that GVN does not crash when PHI-translating a load address whose cast
; operand folds to a global constant shared with another function. The cast
; reuse scan must skip casts from other functions to avoid querying this
; function's DominatorTree with a foreign block.

@g1 = global i8 1
@g2 = global i8 2

define i8 @victim(i1 %take.select, i1 %choose.g1) {
; CHECK-LABEL: @victim(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    br i1 [[TAKE_SELECT:%.*]], label [[SELECT_BB:%.*]], label [[MERGE:%.*]]
; CHECK:       select.bb:
; CHECK-NEXT:    [[SELECTED:%.*]] = select i1 [[CHOOSE_G1:%.*]], i64 ptrtoint (ptr @g1 to i64), i64 ptrtoint (ptr @g2 to i64)
; CHECK-NEXT:    br label [[MERGE]]
; CHECK:       merge:
; CHECK-NEXT:    [[ADDRESS_INT:%.*]] = phi i64 [ 0, [[ENTRY:%.*]] ], [ [[SELECTED]], [[SELECT_BB]] ]
; CHECK-NEXT:    [[ADDRESS_FP:%.*]] = uitofp i64 [[ADDRESS_INT]] to double
; CHECK-NEXT:    [[ADDRESS_ROUNDTRIP:%.*]] = fptoui double [[ADDRESS_FP]] to i64
; CHECK-NEXT:    [[ADDRESS:%.*]] = inttoptr i64 [[ADDRESS_ROUNDTRIP]] to ptr
; CHECK-NEXT:    [[VALUE:%.*]] = load i8, ptr [[ADDRESS]], align 1
; CHECK-NEXT:    ret i8 [[VALUE]]
;
entry:
  br i1 %take.select, label %select.bb, label %merge

select.bb:
  %selected = select i1 %choose.g1, i64 ptrtoint (ptr @g1 to i64), i64 ptrtoint (ptr @g2 to i64)
  br label %merge

merge:
  %address.int = phi i64 [ 0, %entry ], [ %selected, %select.bb ]
  %address.fp = uitofp i64 %address.int to double
  %address.roundtrip = fptoui double %address.fp to i64
  %address = inttoptr i64 %address.roundtrip to ptr
  %value = load i8, ptr %address, align 1
  ret i8 %value
}

; A cast of the same constant expression in a different function. This is what
; places a foreign block on the constant's use-list.
define double @foreign_user() {
; CHECK-LABEL: @foreign_user(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    [[FOREIGN_CAST:%.*]] = uitofp i64 ptrtoint (ptr @g1 to i64) to double
; CHECK-NEXT:    ret double [[FOREIGN_CAST]]
;
entry:
  %foreign.cast = uitofp i64 ptrtoint (ptr @g1 to i64) to double
  ret double %foreign.cast
}
