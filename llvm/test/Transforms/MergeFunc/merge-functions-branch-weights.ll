else:
  ret i32 8
}

define internal i32 @br_one_b(i32 %x) !prof !6 {
entry:
  %cmp = icmp sgt i32 %x, 0
  br i1 %cmp, label %then, label %else, !prof !7

then:
  ret i32 7

else:
  ret i32 8
}

