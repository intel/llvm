; CHECK-NEXT:    [[V1:%.*]] = load i32, ptr [[P_1]], align 4
; CHECK-NEXT:    [[ADD:%.*]] = add i32 [[V0]], [[F]]
; CHECK-NEXT:    [[R0:%.*]] = insertelement <2 x i32> poison, i32 [[ADD]], i32 0
; CHECK-NEXT:    [[R1:%.*]] = insertelement <2 x i32> [[R0]], i32 [[V1]], i32 1
