; CHECK-NEXT:    br i1 [[CMP]], label %[[THEN:.*]], label %[[ELSE:.*]]
; CHECK:       [[THEN]]:
; CHECK-NEXT:    [[RES:%.*]] = icmp sge i64 [[C]], 0
; CHECK-NEXT:    ret i1 [[RES]]
; CHECK:       [[ELSE]]:
; CHECK-NEXT:    ret i1 false
;
