; RUN: opt -passes=constraint-elimination -S %s | FileCheck %s

; (%b | %c) >=s 0 implies both %b >=s 0 and %c >=s 0.
define i1 @or_non_negative_bounds(i64 %a, i64 %b, i64 %c, i64 %d) {
; CHECK-LABEL: define i1 @or_non_negative_bounds(
; CHECK-SAME: i64 [[A:%.*]], i64 [[B:%.*]], i64 [[C:%.*]], i64 [[D:%.*]]) {
; CHECK-NEXT:    [[O:%.*]] = or i64 [[C]], [[B]]
; CHECK-NEXT:    [[NONNEG:%.*]] = icmp sgt i64 [[O]], -1
; CHECK-NEXT:    [[ADD:%.*]] = add nsw i64 [[C]], [[B]]
; CHECK-NEXT:    [[CMP_1:%.*]] = icmp sle i64 [[ADD]], [[A]]
; CHECK-NEXT:    [[CMP_2:%.*]] = icmp sgt i64 [[D]], -1
; CHECK-NEXT:    [[CMP_3:%.*]] = icmp slt i64 [[D]], [[C]]
; CHECK-NEXT:    [[AND_1:%.*]] = and i1 [[CMP_1]], [[CMP_3]]
; CHECK-NEXT:    [[AND_2:%.*]] = and i1 [[CMP_2]], [[AND_1]]
; CHECK-NEXT:    [[AND_3:%.*]] = and i1 [[NONNEG]], [[AND_2]]
; CHECK-NEXT:    br i1 [[AND_3]], label %[[THEN:.*]], label %[[ELSE:.*]]
; CHECK:       [[THEN]]:
; CHECK-NEXT:    [[IDX:%.*]] = add nsw i64 [[D]], [[B]]
; CHECK-NEXT:    [[RES:%.*]] = icmp ult i64 [[IDX]], [[A]]
; CHECK-NEXT:    ret i1 [[RES]]
; CHECK:       [[ELSE]]:
; CHECK-NEXT:    ret i1 false
;
  %o = or i64 %c, %b
  %nonneg = icmp sgt i64 %o, -1
  %add = add nsw i64 %c, %b
  %cmp.1 = icmp sle i64 %add, %a
  %cmp.2 = icmp sgt i64 %d, -1
  %cmp.3 = icmp slt i64 %d, %c
  %and.1 = and i1 %cmp.1, %cmp.3
  %and.2 = and i1 %cmp.2, %and.1
  %and.3 = and i1 %nonneg, %and.2
  br i1 %and.3, label %then, label %else

then:
  %idx = add nsw i64 %d, %b
  %res = icmp ult i64 %idx, %a
  ret i1 %res

else:
  ret i1 false
}

