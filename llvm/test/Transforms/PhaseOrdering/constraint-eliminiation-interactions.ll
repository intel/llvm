define void @sum_of_induction_and_guard(i8 %n, i8 %j) mustprogress {
; CHECK-LABEL: define void @sum_of_induction_and_guard(
; CHECK-SAME: i8 [[N:%.*]], i8 [[J:%.*]]) local_unnamed_addr #[[ATTR0:[0-9]+]] {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    [[PRE_0:%.*]] = icmp sgt i8 [[N]], 10
; CHECK-NEXT:    tail call void @llvm.assume(i1 [[PRE_0]])
; CHECK-NEXT:    [[C_NOT1:%.*]] = icmp eq i8 [[N]], 11
; CHECK-NEXT:    br i1 [[C_NOT1]], label %[[EXIT:.*]], label %[[BODY:.*]]
; CHECK:       [[BODY]]:
; CHECK-NEXT:    [[IV_NEXT2:%.*]] = phi i8 [ [[IV_NEXT:%.*]], %[[BODY]] ], [ 11, %[[ENTRY]] ]
; CHECK-NEXT:    tail call void @use(i32 1)
; CHECK-NEXT:    [[IV_NEXT]] = add i8 [[IV_NEXT2]], 1
; CHECK-NEXT:    [[C_NOT:%.*]] = icmp eq i8 [[IV_NEXT]], [[N]]
; CHECK-NEXT:    br i1 [[C_NOT]], label %[[EXIT]], label %[[BODY]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret void
;
entry:
  %pre.0 = icmp sgt i8 %n, 10
  %pre.1 = icmp sge i8 %j, 20
  call void @llvm.assume(i1 %pre.0)
  call void @llvm.assume(i1 %pre.1)
  br label %loop.header

loop.header:
  %iv = phi i8 [ 10, %entry ], [ %iv.next, %loop.latch ]
  %iv.next = add i8 %iv, 1
  %c = icmp ne i8 %iv.next, %n
  br i1 %c, label %body, label %exit

body:
  %sum = add nsw i8 %iv, %j
  %t = icmp sge i8 %sum, 30
  br i1 %t, label %then, label %els

then:
  tail call void @use(i32 1)
  br label %loop.latch

els:
  tail call void @use(i32 2)
  br label %loop.latch

loop.latch:
  br label %loop.header

exit:
  ret void
}

