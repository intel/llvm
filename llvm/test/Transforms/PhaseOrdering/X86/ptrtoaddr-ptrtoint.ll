; CHECK:       [[TRAP]]:
; CHECK-NEXT:    [[A_TR9_LCSSA]] = phi ptr [ [[A]], %[[BODY_PREHEADER]] ], [ null, %[[BODY]] ]
; CHECK-NEXT:    store volatile i32 0, ptr [[A_TR9_LCSSA]], align 4
; CHECK-NEXT:    br label %[[COMMON_RET]]
;
entry:
  %in.bounds = icmp ult ptr %p, %end
  br i1 %in.bounds, label %body, label %common.ret

common.ret:
  %ret = phi ptr [ %a, %trap ], [ null, %recurse ], [ null, %advance ], [ null, %entry ]
  ret ptr %ret

body:
  %char = load i8, ptr %p, align 1
  switch i8 %char, label %trap [
  i8 33, label %advance
  i8 36, label %advance
  ]

advance:
  %p.next = getelementptr i8, ptr %p, i64 1
  %next.in.bounds = icmp ult ptr %p.next, %end
  br i1 %next.in.bounds, label %recurse, label %common.ret

recurse:
  %rec = call ptr @gep_base_cancel(ptr %p.next, ptr %end)
  br label %common.ret

trap:
  store volatile i32 0, ptr %a, align 4
  br label %common.ret
}
