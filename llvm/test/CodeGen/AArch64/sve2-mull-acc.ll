; Select mull + add/sub into mlal/mlsl

define <vscale x 4 x i32> @smlalb_from_add_smullb(<vscale x 4 x i32> %acc, <vscale x 8 x i16> %a, <vscale x 8 x i16> %b) {
; CHECK-LABEL: smlalb_from_add_smullb:
; CHECK:       // %bb.0:
; CHECK-NEXT:    smlalb z0.s, z1.h, z2.h
; CHECK-NEXT:    ret
  %mul = call <vscale x 4 x i32> @llvm.aarch64.sve.smullb.nxv4i32(<vscale x 8 x i16> %a, <vscale x 8 x i16> %b)
  %r = add <vscale x 4 x i32> %mul, %acc
  ret <vscale x 4 x i32> %r
}

