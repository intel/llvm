name:            can_fold_i8
tracksRegLiveness: true
body:             |
  ; CHECK-LABEL: name: can_fold_i8
  ; CHECK: bb.0.entry:
  ; CHECK-NEXT:   successors: %bb.1(0x00000800), %bb.2(0x7ffff800)
  ; CHECK-NEXT:   liveins: $w0, $w1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   [[COPY:%[0-9]+]]:_(i32) = COPY $w0
  ; CHECK-NEXT:   [[ASSERT_ZEXT:%[0-9]+]]:_(i32) = G_ASSERT_ZEXT [[COPY]], 8
  ; CHECK-NEXT:   [[COPY1:%[0-9]+]]:_(i32) = COPY $w1
  ; CHECK-NEXT:   [[ASSERT_ZEXT1:%[0-9]+]]:_(i32) = G_ASSERT_ZEXT [[COPY1]], 8
  ; CHECK-NEXT:   [[ADD:%[0-9]+]]:_(i32) = G_ADD [[ASSERT_ZEXT]], [[ASSERT_ZEXT1]]
  ; CHECK-NEXT:   [[C:%[0-9]+]]:_(s32) = G_CONSTANT i32 256
  ; CHECK-NEXT:   [[AND:%[0-9]+]]:_(i32) = G_AND [[ADD]], [[C]]
  ; CHECK-NEXT:   [[C1:%[0-9]+]]:_(s32) = G_CONSTANT i32 0
  ; CHECK-NEXT:   [[ICMP:%[0-9]+]]:_(i1) = G_ICMP intpred(eq), [[AND]](i32), [[C1]]
  ; CHECK-NEXT:   G_BRCOND [[ICMP]](i1), %bb.2
  ; CHECK-NEXT:   G_BR %bb.1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   successors:
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   G_TRAP
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.2:
  ; CHECK-NEXT:   $w0 = COPY [[ADD]](i32)
  ; CHECK-NEXT:   RET_ReallyLR implicit $w0
  bb.1.entry:
    successors: %bb.2(0x00000800), %bb.3(0x7ffff800)
    liveins: $w0, $w1

    %2:_(i32) = COPY $w0
    %3:_(i32) = G_ASSERT_ZEXT %2, 8
    %0:_(i8) = G_TRUNC %3(i32)
    %4:_(i32) = COPY $w1
    %5:_(i32) = G_ASSERT_ZEXT %4, 8
    %1:_(i8) = G_TRUNC %5(i32)
    %6:_(i8), %7:_(i1) = G_UADDO %0, %1
    G_BRCOND %7(i1), %bb.2
    G_BR %bb.3

  bb.2:
    successors:

    G_TRAP

  bb.3:
    %8:_(i32) = G_ZEXT %6(i8)
    $w0 = COPY %8(i32)
    RET_ReallyLR implicit $w0

