  ; CHECK-NEXT:   [[TRUNC1:%[0-9]+]]:_(i16) = G_TRUNC [[ASSERT_ZEXT1]](i32)
  ; CHECK-NEXT:   [[C:%[0-9]+]]:_(i32) = G_CONSTANT i32 10
  ; CHECK-NEXT:   [[UADDO:%[0-9]+]]:_(i16), [[UADDO1:%[0-9]+]]:_(i1) = G_UADDO [[TRUNC]], [[TRUNC1]]
  ; CHECK-NEXT:   [[ANYEXT:%[0-9]+]]:_(i32) = G_ANYEXT [[UADDO]](i16)
  ; CHECK-NEXT:   G_BRCOND [[UADDO1]](i1), %bb.2
  ; CHECK-NEXT:   G_BR %bb.1
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.1:
  ; CHECK-NEXT:   [[PHI:%[0-9]+]]:_(i32) = G_PHI [[C]](i32), %bb.2, [[ANYEXT]](i32), %bb.0
  ; CHECK-NEXT:   $w0 = COPY [[PHI]](i32)
  ; CHECK-NEXT:   RET_ReallyLR implicit $w0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.2:
  ; CHECK-NEXT:   successors: %bb.1(0x80000000)
