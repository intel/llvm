---
name:            v4s32
legalized:       true
body: |
  bb.0.entry:
    liveins: $q0
    ; CHECK-LABEL: name: v4s32
    ; CHECK: liveins: $q0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %v1:_(<4 x f32>) = COPY $q0
    ; CHECK-NEXT: %unmerge:_(<2 x f32>) = G_EXTRACT_SUBVECTOR %v1(<4 x f32>), 2
    ; CHECK-NEXT: %fpext:_(<2 x f64>) = G_FPEXT %unmerge(<2 x f32>)
    ; CHECK-NEXT: $q0 = COPY %fpext(<2 x f64>)
    ; CHECK-NEXT: RET_ReallyLR implicit $q0
    %v1:_(<4 x f32>) = COPY $q0
    %implicit:_(<4 x f32>) = G_IMPLICIT_DEF
    %C:_(i32) = G_CONSTANT i32 8
    %ext:_(<4 x f32>) = G_EXT %v1:_, %implicit:_, %C:_(i32)
    %unmerge:_(<2 x f32>), %unused:_(<2 x f32>) = G_UNMERGE_VALUES %ext:_(<4 x f32>)
    %fpext:_(<2 x f64>) = G_FPEXT %unmerge:_(<2 x f32>)
    $q0 = COPY %fpext
    RET_ReallyLR implicit $q0
...
