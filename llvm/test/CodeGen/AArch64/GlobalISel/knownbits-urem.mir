# RUN: llc -mtriple aarch64 -passes="print<gisel-value-tracking>" %s -filetype=null 2>&1 | FileCheck %s

# CHECK-LABEL: name: @urem_pow2
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:00000000000000000000000000001000 SignBits:28
# CHECK-NEXT: %2:_ KnownBits:00000000000000000000000000000??? SignBits:29

name: urem_pow2
body: |
  bb.1:
    liveins: $w0

    %0:_(i32) = COPY $w0
    %1:_(i32) = G_CONSTANT i32 8
    %2:_(i32) = G_UREM %0, %1
    $w0 = COPY %2(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @urem_non_pow2
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:00000000000000000000000000001010 SignBits:28
# CHECK-NEXT: %2:_ KnownBits:0000000000000000000000000000???? SignBits:28

name: urem_non_pow2
body: |
  bb.1:
    liveins: $w0

    %0:_(i32) = COPY $w0
    %1:_(i32) = G_CONSTANT i32 10
    %2:_(i32) = G_UREM %0, %1
    $w0 = COPY %2(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @urem
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %2:_ KnownBits:???????????????????????????????? SignBits:1

name: urem
body: |
  bb.1:
    liveins: $w0, $w1

    %0:_(i32) = COPY $w0
    %1:_(i32) = COPY $w1
    %2:_(i32) = G_UREM %0, %1
    $w0 = COPY %2(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @urem_implicit_def
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:00000000000000000000000000001000 SignBits:28
# CHECK-NEXT: %2:_ KnownBits:00000000000000000000000000000??? SignBits:29

name: urem_implicit_def
body: |
  bb.1:
    liveins: $w0

    %0:_(i32) = G_IMPLICIT_DEF
    %1:_(i32) = G_CONSTANT i32 8
    %2:_(i32) = G_UREM %0, %1
    $w0 = COPY %2(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @urem_both_implicit_def
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %2:_ KnownBits:???????????????????????????????? SignBits:1

name: urem_both_implicit_def
body: |
  bb.1:

    %0:_(i32) = G_IMPLICIT_DEF
    %1:_(i32) = G_IMPLICIT_DEF
    %2:_(i32) = G_UREM %0, %1
    $w0 = COPY %2(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @urem_const_const
# CHECK-NEXT: %0:_ KnownBits:00000000000000000000000000001010 SignBits:28
# CHECK-NEXT: %1:_ KnownBits:00000000000000000000000000000011 SignBits:30
# CHECK-NEXT: %2:_ KnownBits:000000000000000000000000000000?? SignBits:30

name: urem_const_const
body: |
  bb.1:

    %0:_(i32) = G_CONSTANT i32 10
    %1:_(i32) = G_CONSTANT i32 3
    %2:_(i32) = G_UREM %0, %1
    $w0 = COPY %2(i32)
    RET_ReallyLR implicit $w0
...

# The divisor is 0 (excluded: UB) or 8, so the result is at most 7: the
# leading-zero count comes from MaxRHS - 1, not MaxRHS.
# CHECK-LABEL: name: @urem_masked_divisor
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %2:_ KnownBits:00000000000000000000000000001000 SignBits:28
# CHECK-NEXT: %3:_ KnownBits:0000000000000000000000000000?000 SignBits:28
# CHECK-NEXT: %4:_ KnownBits:00000000000000000000000000000??? SignBits:29

name: urem_masked_divisor
body: |
  bb.1:
    liveins: $w0, $w1

    %0:_(i32) = COPY $w0
    %1:_(i32) = COPY $w1
    %2:_(i32) = G_CONSTANT i32 8
    %3:_(i32) = G_AND %1, %2
    %4:_(i32) = G_UREM %0, %3
    $w0 = COPY %4(i32)
    RET_ReallyLR implicit $w0
...

# The LHS is 4 or 5 and the divisor is at least 8, so the result is the LHS,
# including its known one bit.
# CHECK-LABEL: name: @urem_lhs_known_smaller
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %2:_ KnownBits:00000000000000000000000000000001 SignBits:31
# CHECK-NEXT: %3:_ KnownBits:0000000000000000000000000000000? SignBits:31
# CHECK-NEXT: %4:_ KnownBits:00000000000000000000000000000100 SignBits:29
# CHECK-NEXT: %5:_ KnownBits:0000000000000000000000000000010? SignBits:29
# CHECK-NEXT: %6:_ KnownBits:00000000000000000000000000001000 SignBits:28
# CHECK-NEXT: %7:_ KnownBits:????????????????????????????1??? SignBits:1
# CHECK-NEXT: %8:_ KnownBits:0000000000000000000000000000010? SignBits:29

name: urem_lhs_known_smaller
body: |
  bb.1:
    liveins: $w0, $w1

    %0:_(i32) = COPY $w0
    %1:_(i32) = COPY $w1
    %2:_(i32) = G_CONSTANT i32 1
    %3:_(i32) = G_AND %0, %2
    %4:_(i32) = G_CONSTANT i32 4
    %5:_(i32) = G_OR %3, %4
    %6:_(i32) = G_CONSTANT i32 8
    %7:_(i32) = G_OR %1, %6
    %8:_(i32) = G_UREM %5, %7
    $w0 = COPY %8(i32)
    RET_ReallyLR implicit $w0
...
