---
name:            ssubo_arith_extended
alignment:       4
legalized:       true
regBankSelected: true
tracksRegLiveness: true
body:             |
  bb.1.entry:
    liveins: $w0, $x0
    ; Check that we get ADDSXrx.
    ; CHECK-LABEL: name: ssubo_arith_extended
    ; CHECK: liveins: $w0, $x0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %reg0:gpr64sp = COPY $x0
    ; CHECK-NEXT: %reg1:gpr32 = COPY $w0
    ; CHECK-NEXT: %add:gpr64 = SUBSXrx %reg0, %reg1, 18, implicit-def $nzcv
    ; CHECK-NEXT: $x0 = COPY %add
    ; CHECK-NEXT: RET_ReallyLR implicit $x0
    %reg0:gpr(i64) = COPY $x0
    %reg1:gpr(i32) = COPY $w0
    %ext:gpr(i64) = G_ZEXT %reg1(i32)
    %cst:gpr(i64) = G_CONSTANT i64 2
    %shift:gpr(i64) = G_SHL %ext, %cst(i64)
    %add:gpr(i64), %flags:gpr(i32) = G_SSUBO %reg0, %shift
    $x0 = COPY %add(i64)
    RET_ReallyLR implicit $x0
