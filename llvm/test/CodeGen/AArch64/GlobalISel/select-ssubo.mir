name:            ssubo_s32_shifted
alignment:       4
legalized:       true
regBankSelected: true
tracksRegLiveness: true
body:             |
  bb.1.entry:
    liveins: $w0, $w1, $x2
    ; Check that we get ADDSWrs when we can fold in a shift.
    ; CHECK-LABEL: name: ssubo_s32_shifted
    ; CHECK: liveins: $w0, $w1, $x2
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %copy1:gpr32 = COPY $w0
    ; CHECK-NEXT: %copy2:gpr32 = COPY $w1
    ; CHECK-NEXT: %add:gpr32 = SUBSWrs %copy1, %copy2, 16, implicit-def $nzcv
    ; CHECK-NEXT: $w0 = COPY %add
    ; CHECK-NEXT: RET_ReallyLR implicit $w0
    %copy1:gpr(i32) = COPY $w0
    %copy2:gpr(i32) = COPY $w1
    %constant:gpr(i32) = G_CONSTANT i32 16
    %shift:gpr(i32) = G_SHL %copy2(i32), %constant(i32)
    %add:gpr(i32), %overflow:gpr(i32) = G_SSUBO %copy1, %shift
    $w0 = COPY %add(i32)
    RET_ReallyLR implicit $w0

