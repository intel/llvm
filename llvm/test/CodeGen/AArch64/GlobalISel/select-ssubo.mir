    ; CHECK-NEXT: $w0 = COPY [[SUBSWrr]]
    ; CHECK-NEXT: $w1 = COPY [[CSINCWr]]
    ; CHECK-NEXT: RET_ReallyLR implicit $w0, implicit $w1
    %0:gpr(i32) = COPY $w0
    %1:gpr(i32) = COPY $w1
    %3:gpr(i32), %4:gpr(i32) = G_SSUBO %0, %1
