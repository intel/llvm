name:            ssubo_s32_imm
alignment:       4
legalized:       true
regBankSelected: true
tracksRegLiveness: true
body:             |
  bb.1.entry:
    liveins: $w0, $w1, $x2
    ; Check that we get ADDSWri when we can fold in a constant.
    ; CHECK-LABEL: name: ssubo_s32_imm
    ; CHECK: liveins: $w0, $w1, $x2
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %copy:gpr32sp = COPY $w0
    ; CHECK-NEXT: %add:gpr32 = SUBSWri %copy, 16, 0, implicit-def $nzcv
    ; CHECK-NEXT: $w0 = COPY %add
    ; CHECK-NEXT: RET_ReallyLR implicit $w0
    %copy:gpr(i32) = COPY $w0
    %constant:gpr(i32) = G_CONSTANT i32 16
    %add:gpr(i32), %overflow:gpr(i32) = G_SSUBO %copy, %constant
    $w0 = COPY %add(i32)
    RET_ReallyLR implicit $w0

