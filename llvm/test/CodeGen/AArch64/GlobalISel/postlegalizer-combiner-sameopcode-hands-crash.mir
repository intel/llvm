    ; CHECK-NEXT: $w0 = COPY [[AND]](i32)
    ; CHECK-NEXT: RET_ReallyLR implicit $w0
    %1:_(p0) = G_CONSTANT i64 0
    %6:_(i32) = G_CONSTANT i32 0
    %9:_(i1) = G_CONSTANT i1 false
    %0:_(i16) = G_LOAD %1(p0) :: (load (i16), align 8)
    %2:_(i32) = G_ZEXT %0(i16)
    %3:_(i16) = G_LOAD %1(p0) :: (load (i16))
    %4:_(i32) = G_ZEXT %3(i16)
    %5:_(i32) = G_AND %4, %2
    $w0 = COPY %5(i32)
    RET_ReallyLR implicit $w0

