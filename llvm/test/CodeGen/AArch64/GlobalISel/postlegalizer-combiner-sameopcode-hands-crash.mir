alignment:       4
tracksRegLiveness: true
legalized:         true
body:             |
  bb.1:
    ; CHECK-LABEL: name: crash_fn
    ; CHECK: [[C:%[0-9]+]]:_(p0) = G_CONSTANT i64 0
