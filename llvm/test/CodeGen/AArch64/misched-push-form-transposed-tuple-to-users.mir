# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 6
# RUN: llc -mtriple=aarch64-linux-gnu -mattr=+sme2 -force-streaming -verify-machineinstrs -enable-subreg-liveness -run-pass=machine-scheduler %s -o - | FileCheck %s

# Tests the machine scheduler pushes FORM_TRANSPOSED_REG instructions to where they are used.
---
name: schedule_form_transpose_adjacent_to_use
tracksRegLiveness: true
body:             |
  bb.0.entry:
    ; CHECK-LABEL: name: schedule_form_transpose_adjacent_to_use
    ; CHECK: [[DEF:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF1:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF2:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF3:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[FORM_TR:%[0-9]+]]:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO [[DEF]].zsub0, [[DEF1]].zsub0, [[DEF2]].zsub0, [[DEF3]].zsub0
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR]], 32
    ; CHECK-NEXT: [[FORM_TR1:%[0-9]+]]:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO [[DEF]].zsub1, [[DEF1]].zsub1, [[DEF2]].zsub1, [[DEF3]].zsub1
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B1:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR1]], 32
    ; CHECK-NEXT: [[FORM_TR2:%[0-9]+]]:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO [[DEF]].zsub2, [[DEF1]].zsub2, [[DEF2]].zsub2, [[DEF3]].zsub2
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B2:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR2]], 32
    ; CHECK-NEXT: [[FORM_TR3:%[0-9]+]]:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO [[DEF]].zsub3, [[DEF1]].zsub3, [[DEF2]].zsub3, [[DEF3]].zsub3
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B3:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR3]], 32
    ; CHECK-NEXT: FAKE_USE [[SQRSHR_VG4_Z4ZI_B]], [[SQRSHR_VG4_Z4ZI_B1]], [[SQRSHR_VG4_Z4ZI_B2]], [[SQRSHR_VG4_Z4ZI_B3]]
    ; CHECK-NEXT: RET_ReallyLR
    %0:zpr4stridedorcontiguous = IMPLICIT_DEF
    %1:zpr4stridedorcontiguous = IMPLICIT_DEF
    %2:zpr4stridedorcontiguous = IMPLICIT_DEF
    %3:zpr4stridedorcontiguous = IMPLICIT_DEF
    %4:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO %0.zsub0, %1.zsub0, %2.zsub0, %3.zsub0
    %5:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO %0.zsub1, %1.zsub1, %2.zsub1, %3.zsub1
    %6:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO %0.zsub2, %1.zsub2, %2.zsub2, %3.zsub2
    %7:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO %0.zsub3, %1.zsub3, %2.zsub3, %3.zsub3
    %8:zpr = SQRSHR_VG4_Z4ZI_B %4, 32
    %9:zpr = SQRSHR_VG4_Z4ZI_B %5, 32
    %10:zpr = SQRSHR_VG4_Z4ZI_B %6, 32
    %11:zpr = SQRSHR_VG4_Z4ZI_B %7, 32
    FAKE_USE %8, %9, %10, %11
    RET_ReallyLR
...
# In this cases the tuples have multiple users. In this case the tuples will be pushed to where they are first used.
---
name: schedule_tuple_used_by_two_instructions
tracksRegLiveness: true
body:             |
  bb.0.entry:
    ; CHECK-LABEL: name: schedule_tuple_used_by_two_instructions
    ; CHECK: [[DEF:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF1:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF2:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[DEF3:%[0-9]+]]:zpr4stridedorcontiguous = IMPLICIT_DEF
    ; CHECK-NEXT: [[FORM_TR:%[0-9]+]]:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO [[DEF]].zsub0, [[DEF1]].zsub0, [[DEF2]].zsub0, [[DEF3]].zsub0
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR]], 16
    ; CHECK-NEXT: [[FORM_TR1:%[0-9]+]]:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO [[DEF]].zsub3, [[DEF1]].zsub3, [[DEF2]].zsub3, [[DEF3]].zsub3
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B1:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR1]], 16
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B2:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR]], 32
    ; CHECK-NEXT: [[SQRSHR_VG4_Z4ZI_B3:%[0-9]+]]:zpr = SQRSHR_VG4_Z4ZI_B [[FORM_TR1]], 32
    ; CHECK-NEXT: FAKE_USE [[SQRSHR_VG4_Z4ZI_B]], [[SQRSHR_VG4_Z4ZI_B1]], [[SQRSHR_VG4_Z4ZI_B2]], [[SQRSHR_VG4_Z4ZI_B3]]
    ; CHECK-NEXT: RET_ReallyLR
    %0:zpr4stridedorcontiguous = IMPLICIT_DEF
    %1:zpr4stridedorcontiguous = IMPLICIT_DEF
    %2:zpr4stridedorcontiguous = IMPLICIT_DEF
    %3:zpr4stridedorcontiguous = IMPLICIT_DEF
    %4:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO %0.zsub0, %1.zsub0, %2.zsub0, %3.zsub0
    %5:zpr4mul4 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO %0.zsub3, %1.zsub3, %2.zsub3, %3.zsub3
    %6:zpr = SQRSHR_VG4_Z4ZI_B %4, 16
    %7:zpr = SQRSHR_VG4_Z4ZI_B %5, 16
    %8:zpr = SQRSHR_VG4_Z4ZI_B %4, 32
    %9:zpr = SQRSHR_VG4_Z4ZI_B %5, 32
    FAKE_USE %6, %7, %8, %9
    RET_ReallyLR
...
