# RUN: not --crash llc -mtriple=amdgpu8.02 -run-pass=machineverifier -filetype=null %s 2>&1 | FileCheck -check-prefix=GFX8-ERR %s
# RUN: llc -mtriple=amdgpu9.00 -run-pass=machineverifier -o - %s 2>&1 | FileCheck -check-prefix=GFX9 %s
# RUN: not --crash llc -mtriple=amdgpu8.02 --passes='machine-function(verify)' -filetype=null %s 2>&1 | FileCheck -check-prefix=GFX8-ERR %s
# RUN: llc -mtriple=amdgpu9.00 --passes='machine-function(verify)' -o - %s 2>&1 | FileCheck -check-prefix=GFX9 %s

# GFX8-ERR: *** Bad machine code: scalar stores must use m0 as offset register ***
# GFX9: S_STORE_DWORD_SGPR
---
name:            scalar_store_soffset_sgpr
body:             |
  bb.0:
    S_STORE_DWORD_SGPR undef $sgpr2, undef $sgpr0_sgpr1, undef $sgpr10, 0
    S_ENDPGM 0

...
