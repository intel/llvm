; CHECK-NEXT:    movl %eax, (%rcx)
; CHECK-NEXT:    addl %edx, %eax
; CHECK-NEXT:    retq
  %s = add i32 %a, %b
  %m = mul i32 %s, 3
  store i32 %m, ptr %p
