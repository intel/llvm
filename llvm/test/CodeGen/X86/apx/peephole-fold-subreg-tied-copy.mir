# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 6
# RUN: llc -mtriple=x86_64-- -mattr=+ndd -run-pass=peephole-opt -verify-machineinstrs -o - %s | FileCheck %s

# Test that foldMemoryOperandImpl doesn't break the machine verifier
# when folding into ND instructions. The newly introduced subregister
# extract must use the correct subregister class of the new use
# instead of the original.

---
name:            add8rm_fold_subreg_tied_copy
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $edi, $rsi

    ; CHECK-LABEL: name: add8rm_fold_subreg_tied_copy
    ; CHECK: liveins: $edi, $rsi
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:gr64 = COPY $rsi
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:gr32 = COPY $edi
    ; CHECK-NEXT: [[COPY2:%[0-9]+]]:gr8 = COPY [[COPY1]].sub_8bit
    ; CHECK-NEXT: [[ADD8rm:%[0-9]+]]:gr8 = ADD8rm [[COPY2]], [[COPY]], 1, $noreg, 0, $noreg, implicit-def dead $eflags :: (load (s8))
    ; CHECK-NEXT: $al = COPY [[ADD8rm]]
    ; CHECK-NEXT: RET 0, $al
    %0:gr64 = COPY $rsi
    %1:gr32 = COPY $edi
    %2:gr8 = MOV8rm %0, 1, $noreg, 0, $noreg :: (load (s8))
    %3:gr8 = ADD8rr_ND %1.sub_8bit, killed %2, implicit-def dead $eflags
    $al = COPY %3
    RET 0, $al
...
