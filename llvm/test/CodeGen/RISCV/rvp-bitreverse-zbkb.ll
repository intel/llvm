; With Zbkb, a per-byte-lane bitreverse (v4i8/v8i8) selects a single brev8
; instead of rev+rev8. Halfword/word lanes still need the rev-based sequence.

define <4 x i8> @test_bitreverse_v4i8(<4 x i8> %a) {
; CHECK-LABEL: test_bitreverse_v4i8:
; CHECK:       # %bb.0:
; CHECK-NEXT:    brev8 a0, a0
; CHECK-NEXT:    ret
  %res = call <4 x i8> @llvm.bitreverse.v4i8(<4 x i8> %a)
  ret <4 x i8> %res
}

