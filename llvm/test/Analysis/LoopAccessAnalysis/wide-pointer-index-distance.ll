entry:
  br label %loop

loop:
  %iv = phi i128 [ 0, %entry ], [ %iv.next, %loop ]
  %gep.load = getelementptr inbounds i32, ptr %A, i128 %iv
  %v = load i32, ptr %gep.load, align 4
  ; Offset whose byte distance needs > 64 bits (~2^66 elements).
