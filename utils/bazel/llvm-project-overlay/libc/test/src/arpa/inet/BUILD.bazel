# Tests for LLVM libc arpa/inet.h functions.

load("//libc/test:libc_test_rules.bzl", "libc_test")

package(default_visibility = ["//visibility:public"])

licenses(["notice"])

libc_test(
    name = "htonl_test",
    srcs = ["htonl_test.cpp"],
    deps = [
        "//libc:__support_common",
        "//libc:htonl",
        "//libc:ntohl",
    ],
)

