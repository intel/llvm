# Tests for LLVM libc socket.h functions.

load("//libc/test:libc_test_rules.bzl", "libc_test", "libc_test_library")

package(default_visibility = ["//visibility:public"])

licenses(["notice"])

libc_test_library(
    name = "socket_test_support",
    hdrs = ["linux/socket_test_support.h"],
    deps = [
        "//libc:__support_common",
        "//libc:__support_cpp_string_view",
        "//libc:chdir",
        "//libc:close",
        "//libc:fchdir",
        "//libc:hdr_fcntl_macros",
        "//libc:hdr_sys_socket_macros",
        "//libc:open",
        "//libc:strncpy",
        "//libc:strnlen",
        "//libc:types_size_t",
        "//libc:types_socklen_t",
        "//libc:types_struct_sockaddr_un",
    ],
)

libc_test(
    name = "bind_test",
    srcs = ["linux/bind_test.cpp"],
    deps = [
