    deps = [
        "//libc:__support_cpp_scope",
        "//libc:close",
        "//libc:fcntl",
        "//libc:getsockopt",
        "//libc:hdr_fcntl_macros",
        "//libc:hdr_sys_socket_macros",
        "//libc:llvm_libc_macros_sys_socket_macros",
        "//libc:memcpy",
        "//libc:memset",
        "//libc:recvmsg",
        "//libc:sendmsg",
        "//libc:socketpair",
        "//libc:types_struct_cmsghdr",
    ],
)

